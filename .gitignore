.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Logs
*.log
streamlit.log
cloudflared.log
localtunnel.log

# Mac OS
.DS_Store

# IDEs
.vscode/
.idea/

# Agent execution history
.agents/
